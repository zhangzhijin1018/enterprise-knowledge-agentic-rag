# 基础应用配置
APP_NAME=Enterprise Knowledge Agentic RAG Platform
APP_ENV=local
APP_DEBUG=false
API_PREFIX=/api/v1
OPENAPI_URL=/openapi.json

# 基础基础设施配置示例
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/enterprise_rag
REDIS_URL=redis://localhost:6379/0
MILVUS_URI=http://localhost:19530

# 模型网关配置示例
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=http://localhost:8001/v1
LLM_API_KEY=your-api-key
LLM_MODEL_NAME=qwen2.5-14b-instruct
LLM_TIMEOUT_SECONDS=30
DEFAULT_LLM_MODEL=gpt-4o-mini

# 经营分析局部 ReAct Planner 配置
# 默认关闭：简单问题继续走确定性 Planner；复杂问题在显式开启后才调用 LLM Gateway。
ANALYTICS_REACT_PLANNER_ENABLED=false
ANALYTICS_REACT_MAX_STEPS=3
